<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        html, body {
            max-width: 1500px;
            height: 100%;
            margin:auto
        }

        div {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
        }

        button {
            width: 320px;
            height: 100px;
            font-family: 'Roboto', sans-serif;
            font-size: 24pt;
            text-transform: uppercase;
            letter-spacing: 2.5px;
            font-weight: 900;
            color: #000;
            background-color: #fff;
            border: none;
            border-radius: 45px;
            box-shadow: 0px 8px 15px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease 0s;
            cursor: pointer;
            outline: none;
            margin: 20px;
        }

        button:hover {
            background-color: #2EE59D;
            box-shadow: 0px 15px 20px rgba(46, 229, 157, 0.4);
            color: #fff;
            transform: translateY(-7px);
        }
    </style>
</head>
<body>
    <div>
        <%for(let i = 0; i < dir.length ; i++){%>
        <button onclick="location.href='<%=dir[i]%>/index.html';"><%=dir[i]%></button>
        <%}%>
    </div>
</body>
</html>